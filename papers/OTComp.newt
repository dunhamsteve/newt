--   rewrite correct x s  in
--   rewrite correct y (eval x |> s) in
--   Refl
-- correct (If b x y) s =
--   rewrite correct b s in
--   rewrite distributeIf (|> s) (eval b) (eval x) (eval y) in
--   rewrite correct x s in
--   rewrite correct y s in
--   Refl
