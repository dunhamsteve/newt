module Erase.IdrisBug

import Prelude
import Data.Fin

-- Idris solves this meta when it shouldn't:
-- https://github.com/idris-lang/Idris2/issues/3680
foo : (0 bang : Nat -> Nat) -> Nat -> Nat
foo = \bang n => _

bar : (0 bang : Nat -> Nat) -> (n : Nat) -> Fin (foo bang n)
bar  = \bang n => FZ {bang n}

